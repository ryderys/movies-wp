# =============================================================================
# PRODUCTION — external/private-network database (on hosting server only)
# =============================================================================
# DB_HOST is your provider's private hostname (e.g. moviestart on IranServer).
# Deploy ON THE SERVER — this will NOT connect from your Windows PC.
#
#   docker compose -f docker-compose.prod.yml -f docker-compose.prod.external-db.yml up -d --build
#   bash scripts/deploy.sh

DB_HOST=moviestart
DB_NAME=wonderful_dewdney
DB_USER=root
DB_PASSWORD=change-me

WP_ENV=production
WP_DEBUG=0
WP_DEBUG_LOG=0
WP_DEBUG_DISPLAY=0

FORCE_SSL_ADMIN=0
DISABLE_XMLRPC=1

# Set after DNS + HTTPS:
# WP_HOME=https://yourdomain.com
# WP_SITEURL=https://yourdomain.com

# =============================================================================
# LOCAL DEV — Docker MySQL (uncomment and comment out PRODUCTION above)
# =============================================================================
# DB_HOST=db
# DB_NAME=local_wp
# DB_USER=wp_user
# DB_PASSWORD=wp_pass
# DB_ROOT_PASSWORD=wp_root_pass
#
# WP_ENV=development
# WP_DEBUG=1
# WP_DEBUG_LOG=1
# WP_DEBUG_DISPLAY=0
# FORCE_SSL_ADMIN=0
# DISABLE_XMLRPC=0
#
# Start: docker compose up -d

# Iran Docker/apt mirrors (optional, outside Iran):
# PHP_IMAGE=php:8.2-apache-bookworm
# MYSQL_IMAGE=mysql:8.0
# APT_MIRROR=deb.debian.org

# Salts: auto-generated in wp-content/.docker-salts.php on first container run.
