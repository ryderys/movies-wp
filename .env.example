# Iran defaults: Arvan (Docker images) + IranServer (apt during build).
# Outside Iran, set in .env:
# PHP_IMAGE=php:8.2-apache-bookworm
# MYSQL_IMAGE=mysql:8.0
# PHPMYADMIN_IMAGE=phpmyadmin:5.2-apache
# APT_MIRROR=deb.debian.org

DB_NAME=local_wp
DB_USER=wp_user
DB_PASSWORD=wp_pass
DB_ROOT_PASSWORD=wp_root_pass

WP_DEBUG=1
WP_DEBUG_LOG=1
WP_DEBUG_DISPLAY=0

# Docker mounts only ./wp-content (not the full project) for speed on Windows.
# Edit themes/plugins under wp-content as usual. After changing core/root files, rebuild:
#   docker compose build wordpress && docker compose up -d
#
# Docker: salts are auto-generated in wp-content/.docker-salts.php on first run.
# Or set AUTH_KEY, SECURE_AUTH_KEY, LOGGED_IN_KEY, NONCE_KEY, AUTH_SALT,
# SECURE_AUTH_SALT, LOGGED_IN_SALT, and NONCE_SALT in the environment.
